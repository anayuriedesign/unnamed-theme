{% comment %}
  Slideshow Robusto - Desenvolvido para Tema Próprio
  Suporta Imagens, Vídeos, Autoplay inteligente, Tipografia avançada e Responsividade.
{% endcomment %}

<style>
  /* --- Estilos Globais do Slideshow --- */
  .custom-slideshow-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #000; /* Fundo fallback */
  }

  .custom-slideshow-track {
    display: flex;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .custom-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.6s ease-in-out;
    display: flex;
    z-index: 1;
    visibility: hidden;
  }

  .custom-slide.is-active {
    opacity: 1;
    z-index: 2;
    visibility: visible;
  }

  .custom-slide-media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
  }

  .custom-slide-media a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .custom-slide-media img,
  .custom-slide-media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .custom-slide-content-wrapper {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: flex;
    padding: 40px;
    box-sizing: border-box;
  }

  .custom-slide-content {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .custom-slide-title, .custom-slide-subtitle {
    margin: 0;
    line-height: 1.2;
  }

  .custom-slide-btn {
    display: inline-block;
    padding: 12px 30px;
    text-decoration: none;
    text-align: center;
    transition: opacity 0.3s ease;
    cursor: pointer;
    border: none;
    width: fit-content;
  }

  .custom-slide-btn:hover {
    opacity: 0.8;
  }

  /* Controles (Dots) */
  .custom-slideshow-dots {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 10;
  }

  .custom-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .custom-dot.is-active {
    background-color: rgba(255, 255, 255, 1);
  }

  /* Desktop Height */
  @media screen and (min-width: 769px) {
    .custom-slideshow-wrapper {
      height: {{ section.settings.height_desktop }}px;
    }
  }

  /* Mobile Height & Adjustments */
  @media screen and (max-width: 768px) {
    .custom-slideshow-wrapper {
      height: {{ section.settings.height_mobile }}px;
    }
    .custom-slide-content-wrapper {
      padding: 20px;
    }
    /* Hide desktop image on mobile, hide mobile on desktop */
    .img-desktop { display: none; }
    .img-mobile { display: block; }
  }

  @media screen and (min-width: 769px) {
    .img-desktop { display: block; }
    .img-mobile { display: none; }
  }
</style>

<div class="custom-slideshow-wrapper" 
     id="Slideshow-{{ section.id }}" 
     data-autoplay="{{ section.settings.autoplay }}" 
     data-delay="{{ section.settings.autoplay_speed }}">
  
  <div class="custom-slideshow-track">
    {% for block in section.blocks %}
      
      {% comment %} 
        Lógica de Alinhamento Flexbox baseada nas configurações
      {% endcomment %}
      {% assign justify_desk = block.settings.pos_desktop | split: '-' | first %}
      {% assign align_desk = block.settings.pos_desktop | split: '-' | last %}
      {% assign justify_mob = block.settings.pos_mobile | split: '-' | first %}
      {% assign align_mob = block.settings.pos_mobile | split: '-' | last %}

      <style>
        /* Estilos Individuais do Bloco {{ block.id }} */
        #Slide-{{ block.id }} .custom-slide-content-wrapper {
          justify-content: {{ justify_desk }};
          align-items: {{ align_desk }};
        }
        
        #Slide-{{ block.id }} .custom-slide-content {
          {% if justify_desk == 'center' %}text-align: center; align-items: center;{% endif %}
          {% if justify_desk == 'flex-end' %}text-align: right; align-items: flex-end;{% endif %}
        }

        #Slide-{{ block.id }} .custom-slide-title {
          font-size: {{ block.settings.title_size_desk }}px;
          font-weight: {{ block.settings.title_weight }};
          color: {{ block.settings.title_color }};
          text-transform: {{ block.settings.title_transform }};
        }

        #Slide-{{ block.id }} .custom-slide-subtitle {
          font-size: {{ block.settings.subtitle_size_desk }}px;
          font-weight: {{ block.settings.subtitle_weight }};
          color: {{ block.settings.subtitle_color }};
          text-transform: {{ block.settings.subtitle_transform }};
        }

        #Slide-{{ block.id }} .custom-slide-btn {
          background-color: {{ block.settings.btn_bg_color }};
          color: {{ block.settings.btn_text_color }};
          border-radius: {{ block.settings.btn_radius }}px;
          font-weight: {{ block.settings.btn_weight }};
          text-transform: {{ block.settings.btn_transform }};
        }

        @media screen and (max-width: 768px) {
          #Slide-{{ block.id }} .custom-slide-content-wrapper {
            justify-content: {{ justify_mob }};
            align-items: {{ align_mob }};
          }
          #Slide-{{ block.id }} .custom-slide-content {
            {% if justify_mob == 'center' %}text-align: center; align-items: center;{% else %}text-align: left; align-items: flex-start;{% endif %}
            {% if justify_mob == 'flex-end' %}text-align: right; align-items: flex-end;{% endif %}
          }
          #Slide-{{ block.id }} .custom-slide-title {
            font-size: {{ block.settings.title_size_mob }}px;
          }
          #Slide-{{ block.id }} .custom-slide-subtitle {
            font-size: {{ block.settings.subtitle_size_mob }}px;
          }
        }
      </style>

      <div class="custom-slide {% if forloop.first %}is-active{% endif %}" id="Slide-{{ block.id }}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        
        <!-- Media (Image or Video) -->
        <div class="custom-slide-media">
          {% if block.settings.link != blank and block.settings.btn_label == blank %}
            <a href="{{ block.settings.link }}">
          {% endif %}

          {% if block.settings.video != blank %}
            {{ block.settings.video | video_tag: autoplay: false, loop: block.settings.video_loop, muted: true, controls: false, image_size: '1200x' }}
          {% else %}
            {% if block.settings.image_desktop != blank %}
              <img src="{{ block.settings.image_desktop | img_url: 'master' }}" class="img-desktop" alt="{{ block.settings.title }}">
            {% endif %}
            {% if block.settings.image_mobile != blank %}
              <img src="{{ block.settings.image_mobile | img_url: 'master' }}" class="img-mobile" alt="{{ block.settings.title }}">
            {% elsif block.settings.image_desktop != blank %}
              <img src="{{ block.settings.image_desktop | img_url: 'master' }}" class="img-mobile" alt="{{ block.settings.title }}">
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag }}
            {% endif %}
          {% endif %}

          {% if block.settings.link != blank and block.settings.btn_label == blank %}
            </a>
          {% endif %}
        </div>

        <!-- Content -->
        <div class="custom-slide-content-wrapper">
          <div class="custom-slide-content">
            {% if block.settings.title != blank %}
              <h2 class="custom-slide-title">{{ block.settings.title }}</h2>
            {% endif %}
            
            {% if block.settings.subtitle != blank %}
              <p class="custom-slide-subtitle">{{ block.settings.subtitle }}</p>
            {% endif %}

            {% if block.settings.btn_label != blank and block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="custom-slide-btn">{{ block.settings.btn_label }}</a>
            {% endif %}
          </div>
        </div>

      </div>
    {% endfor %}
  </div>

  <!-- Controles (Dots) -->
  {% if section.blocks.size > 1 %}
    <div class="custom-slideshow-dots">
      {% for block in section.blocks %}
        <div class="custom-dot {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}"></div>
      {% endfor %}
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sectionId = 'Slideshow-{{ section.id }}';
    const wrapper = document.getElementById(sectionId);
    if (!wrapper) return;

    const slides = wrapper.querySelectorAll('.custom-slide');
    const dots = wrapper.querySelectorAll('.custom-dot');
    const autoplay = wrapper.getAttribute('data-autoplay') === 'true';
    const delay = parseInt(wrapper.getAttribute('data-delay')) * 1000;
    
    let currentIndex = 0;
    let timer = null;
    let startX = 0;
    let endX = 0;

    if (slides.length <= 1) return;

    function goToSlide(index) {
      // Pause previous video if any
      const prevVideo = slides[currentIndex].querySelector('video');
      if (prevVideo) prevVideo.pause();

      slides[currentIndex].classList.remove('is-active');
      if (dots.length > 0) dots[currentIndex].classList.remove('is-active');

      currentIndex = index;

      slides[currentIndex].classList.add('is-active');
      if (dots.length > 0) dots[currentIndex].classList.add('is-active');

      manageAutoplay();
    }

    function nextSlide() {
      let next = (currentIndex + 1) % slides.length;
      goToSlide(next);
    }

    function prevSlide() {
      let prev = (currentIndex - 1 + slides.length) % slides.length;
      goToSlide(prev);
    }

    function manageAutoplay() {
      clearTimeout(timer);
      
      const currentSlide = slides[currentIndex];
      const video = currentSlide.querySelector('video');

      // Lógica de Vídeo
      if (video) {
        video.currentTime = 0;
        video.play().catch(e => console.log('Autoplay do vídeo prevenido pelo navegador.'));
        
        // Se o vídeo não tiver loop, passa de slide quando acabar
        if (!video.loop && autoplay) {
          video.onended = nextSlide;
        } 
        // Se tiver loop, ele fica tocando. (Não damos trigger no nextSlide)
      } else if (autoplay) {
        // Se for imagem, usa o timer normal
        timer = setTimeout(nextSlide, delay);
      }
    }

    // Clique nos dots
    dots.forEach(dot => {
      dot.addEventListener('click', function() {
        const index = parseInt(this.getAttribute('data-index'));
        goToSlide(index);
      });
    });

    // Touch/Swipe Logic
    wrapper.addEventListener('touchstart', function(e) {
      startX = e.changedTouches[0].screenX;
    }, {passive: true});

    wrapper.addEventListener('touchend', function(e) {
      endX = e.changedTouches[0].screenX;
      handleSwipe();
    }, {passive: true});

    function handleSwipe() {
      if (endX < startX - 50) nextSlide(); // Swipe left
      if (endX > startX + 50) prevSlide(); // Swipe right
    }

    // Inicia o Slideshow
    manageAutoplay();
  });
</script>

{% schema %}
{
  "name": "Slideshow Personalizado",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Configurações Gerais"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Altura no Desktop",
      "default": 650
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Altura no Mobile",
      "default": 500
