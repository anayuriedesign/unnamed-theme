{% if section.settings.show_promo_bar %}
  {% style %}
    .promo-bar-{{ section.id }} {
      background-color: {{ section.settings.bg_color }};
      color: {{ section.settings.text_color }};
      text-align: center;
      padding: 6px 20px;
      font-size: {{ section.settings.font_size_desktop }}px;
      font-weight: bold;
      text-transform: uppercase;
      position: relative;
      width: 100%;
      box-sizing: border-box;
      z-index: 9999;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 30px;
      transition: filter 0.3s ease; /* Efeito de transição suave */
    }

    /* Regra para o Celular (Mobile) */
    @media screen and (max-width: 768px) {
      .promo-bar-{{ section.id }} {
        font-size: {{ section.settings.font_size_mobile }}px;
      }
    }

    /* Efeito ao passar o mouse em toda a barra */
    .promo-bar-{{ section.id }}:hover {
      filter: brightness(1.1); /* Deixa a cor levemente mais clara/brilhante */
    }

    /* Estilos do Carrossel */
    .promo-bar__carousel {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 15px;
      width: 100%;
      max-width: 800px;
    }

    .promo-bar__messages {
      flex-grow: 1;
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }

    .promo-bar__message {
      display: none;
      width: 100%;
      animation: promoFadeIn 0.4s ease-out forwards;
    }

    .promo-bar__message.active {
      display: block;
    }

    .promo-bar__link-{{ section.id }} {
      color: inherit;
      text-decoration: none;
      display: block;
      width: 100%;
    }

    .promo-bar__link-{{ section.id }}:hover {
      opacity: 0.9;
    }

    /* Setas Minimalistas */
    .promo-bar__arrow {
      background: none;
      border: none;
      color: inherit;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 5px;
      opacity: 0.6;
      transition: opacity 0.3s ease, transform 0.2s ease;
    }

    .promo-bar__arrow:hover {
      opacity: 1;
      transform: scale(1.1);
    }

    .promo-bar__arrow svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
    }

    @keyframes promoFadeIn {
      from { opacity: 0; transform: translateY(4px); }
      to { opacity: 1; transform: translateY(0); }
    }
  {% endstyle %}

  <div class="promo-bar-{{ section.id }} promo-bar-wrapper" id="PromoBar-{{ section.id }}">
    <div class="promo-bar__carousel">
      
      {% comment %} Seta Esquerda (Mostra apenas se houver mais de 1 bloco) {% endcomment %}
      {% if section.blocks.size > 1 %}
        <button class="promo-bar__arrow promo-bar__arrow--prev" id="PrevMsg-{{ section.id }}" aria-label="Mensagem anterior">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z"/>
          </svg>
        </button>
      {% endif %}

      <div class="promo-bar__messages" id="PromoMessages-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="promo-bar__message js-promo-msg {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="promo-bar__link-{{ section.id }}">
            {% endif %}
            
              <span class="promo-bar__text">{{ block.settings.text }}</span>
            
            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
        {% endfor %}

        {% comment %} Fallback caso o usuário não tenha adicionado blocos ainda {% endcomment %}
        {% if section.blocks.size == 0 %}
          <div class="promo-bar__message active js-promo-msg">
             <span class="promo-bar__text">Adicione frases nos blocos da seção</span>
          </div>
        {% endif %}
      </div>

      {% comment %} Seta Direita (Mostra apenas se houver mais de 1 bloco) {% endcomment %}
      {% if section.blocks.size > 1 %}
        <button class="promo-bar__arrow promo-bar__arrow--next" id="NextMsg-{{ section.id }}" aria-label="Próxima mensagem">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
          </svg>
        </button>
      {% endif %}

    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const promoBar = document.getElementById('PromoBar-{{ section.id }}');
      if (!promoBar) return;

      // --- Lógica do Carrossel de Textos ---
      const messages = promoBar.querySelectorAll('.js-promo-msg');
      const prevBtn = document.getElementById('PrevMsg-{{ section.id }}');
      const nextBtn = document.getElementById('NextMsg-{{ section.id }}');
      
      let currentIndex = 0;
      const rotationSpeed = {{ section.settings.autorotate_speed }} * 1000;
      let rotationTimer;

      if (messages.length > 1) {
        function showMessage(index) {
          messages.forEach((msg, i) => {
            if (i === index) {
              msg.classList.add('active');
            } else {
              msg.classList.remove('active');
            }
          });
        }

        function nextMessage() {
          currentIndex = (currentIndex + 1) % messages.length;
          showMessage(currentIndex);
        }

        function prevMessage() {
          currentIndex = (currentIndex - 1 + messages.length) % messages.length;
          showMessage(currentIndex);
        }

        function startTimer() {
          rotationTimer = setInterval(nextMessage, rotationSpeed);
        }

        function resetTimer() {
          clearInterval(rotationTimer);
          startTimer();
        }

        if (nextBtn) {
          nextBtn.addEventListener('click', () => {
            nextMessage();
            resetTimer(); // Reinicia o timer ao clicar manualmente
          });
        }

        if (prevBtn) {
          prevBtn.addEventListener('click', () => {
            prevMessage();
            resetTimer(); // Reinicia o timer ao clicar manualmente
          });
        }

        // Inicia o carrossel automático
        startTimer();

        // Pausa a rotação ao passar o mouse por cima
        promoBar.addEventListener('mouseenter', () => clearInterval(rotationTimer));
        promoBar.addEventListener('mouseleave', startTimer);
      }
    });
  </script>
{% endif %}

{% schema %}
{
  "name": "Barra Promocional",
  "max_blocks": 3,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_promo_bar",
      "label": "Ativar barra promocional",
      "default": true
    },
    {
      "type": "range",
      "id": "autorotate_speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Tempo de troca (Segundos)",
      "default": 4
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de Fundo",
      "default": "#cc2020"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do Texto",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamanho da Fonte (Computador)",
      "default": 12
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Tamanho da Fonte (Celular)",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "frase",
      "name": "Frase Promocional",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto da Promoção",
          "default": "FREE DOMESTIC STANDARD SHIPPING ON ORDERS OVER $30"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link da Barra (Opcional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barra Promocional",
      "blocks": [
        {
          "type": "frase"
        },
        {
          "type": "frase",
          "settings": {
            "text": "10% OFF NA SUA PRIMEIRA COMPRA!"
          }
        }
      ]
    }
  ]
}
{% endschema %}