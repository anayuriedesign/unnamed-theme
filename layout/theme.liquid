<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.accent_color }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ content_for_header }}

    {%- comment -%} Shopify Font Library — carrega as fontes escolhidas no admin {%- endcomment -%}
    {%- assign body_font = settings.body_font -%}
    {%- assign heading_font = settings.heading_font -%}
    {%- assign body_font_bold = body_font | font_modify: 'weight', 'bolder' -%}
    {%- assign body_font_italic = body_font | font_modify: 'style', 'italic' -%}

    <style>
      {{ body_font | font_face: font_display: 'swap' }}
      {{ heading_font | font_face: font_display: 'swap' }}
      {%- if body_font_bold %}{{ body_font_bold | font_face: font_display: 'swap' }}{%- endif %}
      {%- if body_font_italic %}{{ body_font_italic | font_face: font_display: 'swap' }}{%- endif %}

      :root {
        --font-body-family: {{ body_font.family | json }}, {{ body_font.fallback_families }};
        --font-body-style: {{ body_font.style }};
        --font-body-weight: {{ body_font.weight }};
        --font-heading-family: {{ heading_font.family | json }}, {{ heading_font.fallback_families }};
        --font-heading-style: {{ heading_font.style }};
        --font-heading-weight: {{ heading_font.weight }};
      }
    </style>

    {{ 'base.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </head>
  <body class="template-{{ template.name | handle }}">
    <a class="skip-link" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>

    {% sections 'header-group' %}

    <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}
  </body>
</html>
